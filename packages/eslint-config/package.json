{
	"name": "@zayne-labs/eslint-config",
	"type": "module",
	"version": "0.12.5",
	"description": "Zayne Labs' ESLint config preset",
	"author": "Ryan Zayne",
	"license": "MIT",
	"homepage": "https://github.com/zayne-labs/config#readme",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/zayne-labs/config.git"
	},
	"bugs": {
		"url": "https://github.com/zayne-labs/config/issues"
	},
	"keywords": [],
	"sideEffects": false,
	"exports": {
		".": "./dist/index.js",
		"./constants/*": "./dist/constants/*.js",
		"./utils": "./dist/utils.js"
	},
	"bin": "./bin/index.js",
	"files": [
		"bin",
		"dist"
	],
	"engines": {
		"node": ">=20.x"
	},
	"scripts": {
		"build": "pnpm typegen && tsdown",
		"build:dev": "cross-env NODE_ENV=development tsdown",
		"dev": "pnpm build:dev --watch",
		"lint:attw": "attw --pack . --ignore-rules=cjs-resolves-to-esm",
		"lint:eslint": "eslint . --max-warnings=0",
		"lint:format": "prettier --write .",
		"lint:packages": "pnpm dedupe --check",
		"lint:publint": "publint --strict .",
		"lint:type-check": "pnpm typegen && tsc --pretty -p tsconfig.json",
		"release": "pnpm publish --no-git-checks",
		"release:test": "pnpx pkg-pr-new publish",
		"typegen": "tsx scripts/typegen.ts && tsx scripts/versiongen.ts",
		"version-package": "changeset version"
	},
	"peerDependencies": {
		"@eslint-react/eslint-plugin": "catalog:eslint:peer",
		"@next/eslint-plugin-next": "catalog:eslint:peer",
		"@tanstack/eslint-plugin-query": "catalog:eslint:peer",
		"@tanstack/eslint-plugin-router": "catalog:eslint:peer",
		"astro-eslint-parser": "catalog:eslint:peer",
		"eslint": "catalog:eslint:peer",
		"eslint-config-expo": "catalog:eslint:peer",
		"eslint-plugin-astro": "catalog:eslint:peer",
		"eslint-plugin-better-tailwindcss": "catalog:eslint:peer",
		"eslint-plugin-depend": "catalog:eslint:peer",
		"eslint-plugin-erasable-syntax-only": "catalog:eslint:peer",
		"eslint-plugin-jsx-a11y": "catalog:eslint:peer",
		"eslint-plugin-react-hooks": "catalog:eslint:peer",
		"eslint-plugin-react-refresh": "catalog:eslint:peer",
		"eslint-plugin-react-you-might-not-need-an-effect": "catalog:eslint:peer",
		"eslint-plugin-solid": "catalog:eslint:peer",
		"eslint-plugin-svelte": "catalog:eslint:peer",
		"eslint-plugin-vue": "catalog:eslint:peer",
		"eslint-plugin-vuejs-accessibility": "catalog:eslint:peer",
		"eslint-processor-vue-blocks": "catalog:eslint:peer",
		"svelte-eslint-parser": "catalog:eslint:peer",
		"vue-eslint-parser": "catalog:eslint:peer"
	},
