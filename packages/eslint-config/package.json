{
	"name": "@zayne-labs/eslint-config",
	"type": "module",
	"version": "0.12.0",
	"description": "Zayne Labs' ESLint config preset",
	"author": "Ryan Zayne",
	"license": "MIT",
	"homepage": "https://github.com/zayne-labs/config#readme",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/zayne-labs/config.git"
	},
	"bugs": {
		"url": "https://github.com/zayne-labs/config/issues"
	},
	"keywords": [],
	"sideEffects": false,
	"exports": {
		".": "./dist/index.js",
		"./constants/*": "./dist/constants/*.js",
		"./utils": "./dist/utils.js"
	},
	"bin": "./bin/index.js",
	"files": [
		"bin",
		"dist"
	],
	"engines": {
		"node": ">=20.x"
	},
	"scripts": {
		"build": "pnpm typegen && tsdown",
		"build:dev": "cross-env NODE_ENV=development tsdown",
		"dev": "pnpm build:dev --watch",
		"lint:attw": "attw --pack . --ignore-rules=cjs-resolves-to-esm",
		"lint:eslint": "eslint . --max-warnings 0",
		"lint:format": "prettier --write .",
		"lint:packages": "pnpm dedupe --check",
		"lint:publint": "publint --strict .",
		"lint:type-check": "pnpm typegen && tsc --pretty -p tsconfig.json",
		"release": "pnpm publish --no-git-checks",
		"release:test": "pnpx pkg-pr-new publish",
		"typegen": "tsx scripts/typegen.ts",
		"version-package": "changeset version"
	},
	"peerDependencies": {
		"@eslint-react/eslint-plugin": "3.x.x",
		"@next/eslint-plugin-next": "16.x.x",
		"@tanstack/eslint-plugin-query": "5.x.x",
		"@tanstack/eslint-plugin-router": "1.x.x",
		"astro-eslint-parser": "1.x.x",
		"eslint": "10.x.x",
		"eslint-config-expo": "10.x.x",
		"eslint-plugin-astro": "1.x.x",
		"eslint-plugin-better-tailwindcss": "4.x.x",
		"eslint-plugin-depend": "1.x.x",
		"eslint-plugin-erasable-syntax-only": "0.x.x",
		"eslint-plugin-jsx-a11y": "6.x.x",
		"eslint-plugin-react-hooks": "7.x.x",
		"eslint-plugin-react-refresh": "0.x.x",
		"eslint-plugin-react-you-might-not-need-an-effect": "0.x.x",
		"eslint-plugin-solid": "0.x.x",
		"eslint-plugin-svelte": "3.x.x",
		"eslint-plugin-vue": "10.x.x",
		"eslint-processor-vue-blocks": "2.x.x",
		"vue-eslint-parser": "10.x.x"
	},
	"peerDependenciesMeta": {
		"@eslint-react/eslint-plugin": {
