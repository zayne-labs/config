{
	"extends": ["@zayne-labs/tsconfig/base"],

	"compilerOptions": {
		/* If transpiling with TypeScript: */
		"module": "NodeNext",
		"sourceMap": true,
		// "target": "ES2025", // Set to the current version of JS by default (from TS 6.0)
		"outDir": "dist",

		/* If you're building for a library: */
		"declaration": true,

		/* If your code doesn't run in the DOM: */
		"lib": ["ES2025"]
	}
}
